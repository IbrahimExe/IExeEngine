<Window x:Class="FileCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Creator"
        Height="540" Width="660"
        MinHeight="540" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>
        <!-- Label style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <!-- Input TextBox style -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#313244"/>
            <Setter Property="Foreground"      Value="#CDD6F4"/>
            <Setter Property="BorderBrush"     Value="#45475A"/>
            <Setter Property="CaretBrush"      Value="#CDD6F4"/>
            <Setter Property="SelectionBrush"  Value="#89B4FA"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ComboBox style -->
        <Style x:Key="InputCombo" TargetType="ComboBox">
            <Setter Property="Background"  Value="#313244"/>
            <Setter Property="Foreground"  Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Padding"     Value="6,4"/>
        </Style>

        <!-- Primary button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"        Value="#89B4FA"/>
            <Setter Property="Foreground"        Value="#1E1E2E"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Padding"           Value="20,8"/>
        </Style>

        <!-- Log TextBox style -->
        <Style x:Key="LogBox" TargetType="TextBox">
            <Setter Property="Background"      Value="#181825"/>
            <Setter Property="Foreground"      Value="#A6ADC8"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="11.5"/>
            <Setter Property="BorderBrush"     Value="#313244"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="IsReadOnly"      Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="TextWrapping"    Value="Wrap"/>
            <Setter Property="Padding"         Value="8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header bar -->
            <RowDefinition Height="Auto"/>
            <!-- Form area -->
            <RowDefinition Height="*"/>
            <!-- Log area -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#181825" Padding="20,14">
            <StackPanel>
                <TextBlock x:Name="TitleLabel"
                           Text="File Creator"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#CDD6F4"/>
                <TextBlock x:Name="SubtitleLabel"
                           Text="Add new .h / .cpp files to your engine's Framework projects"
                           FontSize="11"
                           Foreground="#6C7086"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- ═══ FORM ═══ -->
        <Border Grid.Row="1" Padding="20,16" Background="#1E1E2E">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Project dropdown -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Framework Project"
                           Style="{StaticResource FieldLabel}"/>
                <ComboBox  Grid.Row="1" Grid.Column="0"
                           x:Name="ProjectComboBox"
                           Style="{StaticResource InputCombo}"
                           SelectionChanged="OnProjectSelectionChanged">
                    <ComboBoxItem Content="Audio"/>
                    <ComboBoxItem Content="Core"/>
                    <ComboBoxItem Content="Graphics"/>
                    <ComboBoxItem Content="Input"/>
                    <ComboBoxItem Content="Math"/>
                    <ComboBoxItem Content="Physics"/>
                </ComboBox>

                <!-- File name input -->
                <TextBlock Grid.Row="0" Grid.Column="2"
                           Text="File Name (without extension)"
                           Style="{StaticResource FieldLabel}"/>
                <TextBox   Grid.Row="1" Grid.Column="2"
                           x:Name="FileNameBox"
                           Style="{StaticResource InputBox}"
                           Text="e.g. ParticleSystem"
                           TextChanged="OnFileNameChanged"/>

                <!-- Checkboxes row -->
                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                            Orientation="Horizontal">

                    <CheckBox x:Name="IncludeCppCheckBox"
                              Content="Include a .cpp file"
                              IsChecked="True"
                              Foreground="#CDD6F4"
                              FontSize="12"
                              Margin="0,0,24,0"
                              VerticalContentAlignment="Center"/>

                    <Button x:Name="CreateButton"
                            Content="Create Files"
                            Style="{StaticResource PrimaryButton}"
                            Click="OnCreateClicked"
                            IsEnabled="False"
                            HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ LOG ═══ -->
        <Border Grid.Row="2" Padding="20,0,20,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Output"
                           Style="{StaticResource FieldLabel}"
                           Margin="0,8,0,6"/>

                <TextBox Grid.Row="1"
                         x:Name="LogBox"
                         Style="{StaticResource LogBox}"/>
            </Grid>
        </Border>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="3" Background="#181825" Padding="20,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusLabel"
                           Grid.Column="0"
                           Text="Ready"
                           Foreground="#6C7086"
                           FontSize="11"
                           VerticalAlignment="Center"/>

                <TextBlock x:Name="EngineLabel"
                           Grid.Column="1"
                           Foreground="#45475A"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>