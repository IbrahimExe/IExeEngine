<Window x:Class="ProjectCreator.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="300" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings"
                   FontSize="16" FontWeight="Bold" Foreground="#CDD6F4"/>

        <TextBlock Grid.Row="2" Text="Engine Name"
                   Foreground="#A6ADC8" FontSize="12" Margin="0,0,0,4"/>

        <TextBox Grid.Row="3" x:Name="EngineNameBox"
                 FontSize="13" Padding="8,5"
                 Background="#313244" Foreground="#CDD6F4"
                 BorderBrush="#45475A" CaretBrush="#CDD6F4"
                 SelectionBrush="#89B4FA"/>

        <TextBlock Grid.Row="5" Text="Detected Engine Root (read-only)"
                   Foreground="#A6ADC8" FontSize="12" Margin="0,0,0,4"/>

        <TextBox Grid.Row="6" x:Name="EngineRootBox"
                 FontSize="11" FontFamily="Consolas" Padding="8,5"
                 Background="#181825" Foreground="#6C7086"
                 BorderBrush="#313244" IsReadOnly="True" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="OnCancelClicked"
                    Background="Transparent" Foreground="#6C7086"
                    BorderBrush="#45475A" BorderThickness="1"
                    FontSize="12" Padding="16,7" Margin="0,0,10,0" Cursor="Hand"/>
            <Button Content="Save" Click="OnSaveClicked"
                    Background="#89B4FA" Foreground="#1E1E2E"
                    FontWeight="SemiBold" BorderThickness="0"
                    FontSize="12" Padding="16,7" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>